{
  "manifest_version": 3,
  "version": "1.0.0",
  "name": "TimeMate — World Clock for Your Browser",
  "description": "Pin your favorite cities and see their current local time instantly—perfect for international meetings and staying synced with people worldwide.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/logos/logo-light-16.png",
      "32": "icons/logos/logo-light-32.png",
      "48": "icons/logos/logo-light-48.png",
      "128": "icons/logos/logo-light-128.png"
    }
  },
  "icons": {
    "16": "icons/logos/logo-light-16.png",
    "32": "icons/logos/logo-light-32.png",
    "48": "icons/logos/logo-light-48.png",
    "128": "icons/logos/logo-light-128.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"]
}
