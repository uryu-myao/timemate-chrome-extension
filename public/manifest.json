{
  "manifest_version": 3,
  "version": "1.0.0",
  "name": "TimeMate — World Clock for Your Browser",
  "description": "View multiple city time zones in one popup, with search, sorting, and pinning for quick world-time reference.",
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/logos/logo-light-16.png",
      "32": "icons/logos/logo-light-32.png",
      "48": "icons/logos/logo-light-48.png",
      "128": "icons/logos/logo-light-128.png"
    }
  },
  "icons": {
    "16": "icons/logos/logo-light-16.png",
    "32": "icons/logos/logo-light-32.png",
    "48": "icons/logos/logo-light-48.png",
    "128": "icons/logos/logo-light-128.png"
  }
}
